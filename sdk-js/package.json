{
  "name": "@stellarroute/sdk-js",
  "version": "0.1.0",
  "description": "TypeScript SDK for StellarRoute API",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "docs:api": "typedoc",
    "examples:typecheck": "tsc --noEmit -p examples/tsconfig.json",
    "verify": "npm run build && npm run examples:typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
